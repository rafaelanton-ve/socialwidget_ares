{
  "framework": "vue",
  "installCommand": "cd dashboard && npm install",
  "buildCommand": "cd dashboard && npm run build",
  "outputDirectory": "dashboard/dist",
  "rewrites": [
    { "source": "/widget.js", "destination": "/widget/dist/widget.min.js" },
    { "source": "/(.*)", "destination": "/dashboard/dist/index.html" }
  ]
}